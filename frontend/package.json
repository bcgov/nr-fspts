{
  "name": "fsp-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@carbon/icons-react": "^11.64.0",
    "@carbon/react": "^1.105.0",
    "jose": "^5.9.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.54.2",
    "sass": "^1.89.0",
    "typescript": "^5.6.0",
    "vite": "^6.3.1"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "build": "vite build",
    "deploy": "npm ci && vite build",
    "preview": "vite preview",
    "lint": "echo 'lint placeholder — add eslint config in a follow-up' && exit 0",
    "test": "echo 'No unit tests yet' && exit 0",
    "test:ci": "echo 'No unit tests yet' && exit 0",
    "test:coverage": "echo 'No unit tests yet' && exit 0",
    "pree2e:login": "playwright install chromium && rm -f e2e/.auth/user.json",
    "e2e:login": "playwright test --project=setup --headed",
    "pree2e": "playwright install chromium",
    "e2e": "playwright test --project=chromium",
    "pree2e:all-browsers": "playwright install",
    "e2e:all-browsers": "playwright test",
    "pree2e:ui": "playwright install chromium",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  }
}
