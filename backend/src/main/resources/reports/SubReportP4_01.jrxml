	<subDataset name="DDM1" uuid="79a4c0b4-50bd-4110-894d-d731c31ab589">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="JCRS_FSP"/>
		<parameter name="pFSP" class="java.math.BigDecimal"/>
		<queryString language="SQL">
			<![CDATA[select  fsh.fsp_status_code, 
fsh.entry_userid,
case 
 when f.fsp_status_code='SUB' then f.plan_submission_date
 when f.fsp_status_code='INE' then f.plan_start_date
 else null
end sub_eff_date,
fsh.status_comment 
from fsp_status_history fsh join forest_stewardship_plan f on f.fsp_id=fsh.fsp_id and fsh.fsp_amendment_number = f.fsp_amendment_number
where fsh.fsp_status_code='SUB'
and fsh.fsp_id= $P{pFSP}]]>
		</queryString>
		<field name="FSP_STATUS_CODE" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="FSP_STATUS_CODE"/>
			<property name="com.jaspersoft.studio.field.label" value="FSP_STATUS_CODE"/>
		</field>
		<field name="ENTRY_USERID" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="ENTRY_USERID"/>
			<property name="com.jaspersoft.studio.field.label" value="ENTRY_USERID"/>
		</field>
		<field name="SUB_EFF_DATE" class="java.sql.Timestamp">
			<property name="com.jaspersoft.studio.field.name" value="SUB_EFF_DATE"/>
			<property name="com.jaspersoft.studio.field.label" value="SUB_EFF_DATE"/>
		</field>
		<field name="STATUS_COMMENT" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="STATUS_COMMENT"/>
			<property name="com.jaspersoft.studio.field.label" value="STATUS_COMMENT"/>
		</field>
	</subDataset>
