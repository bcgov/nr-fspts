	<parameter name="p_client_number" class="java.lang.String"/>
	<!--
	  p_client_name was present in the original RDD001 variant but
	  dropped in RDD001_1. The live FSPRPT_RDD001_JR proc still takes
	  it (PLS-00306 when omitted). Re-added here as a blank-tolerant
	  String so the call signature matches the DB.
	-->
	<parameter name="p_client_name" class="java.lang.String"/>
	<parameter name="p_fsp_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="p_org_unit_no" class="java.lang.String">
