	</parameter>
	<parameter name="oracle_ref_cursor" class="java.sql.ResultSet" isForPrompting="false"/>
	<queryString language="plsql">
		<![CDATA[{call FSPRPT_RDD001_JR(
$P{oracle_ref_cursor},
$P{p_org_unit_no},
$P{p_client_number},
$P{p_fsp_id},
$P{p_fsp_start_date},
$P{p_fsp_end_date},
$P{p_client_name},
$P{p_userid})
}]]>
	</queryString>
