	<parameter name="pFSP" class="java.math.BigDecimal"/>
	<queryString>
		<![CDATA[SELECT sr.standards_regime_id
	,standards_regime_name
	,standards_objective
	,fsp_amendment_number
	,nvl(bgc_zone_code, ' ') || ', ' || nvl(bgc_subzone_code, '') || ', ' || nvl(bgc_variant, '') || ', ' || nvl(bgc_phase, '') || ', ' || nvl(bec_site_series, '') || ', ' || nvl(bec_site_type, '') || ', ' || nvl(bec_seral, ' ') bgc
	,standards_regime_status_code
	,effective_date
	,mof_default_standard_ind
	,ssid_count
FROM standards_regime sr
JOIN standards_regime_site_series srss ON sr.standards_regime_id = srss.standards_regime_id
JOIN fsp_standards_regime_xref fax ON fax.standards_regime_id = sr.standards_regime_id
JOIN (
	SELECT fax.fsp_id
		,count(1) AS ssid_count
	FROM standards_regime sr
	JOIN standards_regime_site_series srss ON sr.standards_regime_id = srss.standards_regime_id
	JOIN fsp_standards_regime_xref fax ON fax.standards_regime_id = sr.standards_regime_id
	GROUP BY fax.fsp_id
	) cnt ON cnt.FSP_ID = fax.FSP_ID
WHERE fax.FSP_ID = $P{pFSP}
ORDER BY sr.submitted_date DESC

FETCH NEXT 10 ROWS ONLY]]>
	</queryString>
