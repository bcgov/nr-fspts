	<parameter name="pFSP" class="java.math.BigDecimal"/>
	<queryString>
		<![CDATA[select fax.fsp_amendment_number, fa.consolidated_ind, fa.attachment_description, fa.attachment_name, fa.attachment_size
from fsp_attachment fa join fsp_attachment_xref fax on fax.fsp_attachment_id=fa.fsp_attachment_id
where 
fa.fsp_attachment_type_code='SS'
and fax.FSP_ID= $P{pFSP}
Order by fax.fsp_amendment_number desc]]>
	</queryString>
